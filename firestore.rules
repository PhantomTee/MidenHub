rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{midenAddress} {
      allow read, write: if request.auth != null;
    
      match /notifications/{notificationId} {
        function isValidNotification(data) {
          return data.keys().hasAll(['title', 'message', 'read', 'createdAt']) &&
                 data.title is string && data.message is string &&
                 data.read is bool && data.createdAt is number;
        }
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isAdmin() && isValidNotification(request.resource.data);
        allow update: if isSignedIn() && request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    function userHasMidenWallet() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('walletAddress', '') != '';
    }

    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['title', 'description', 'category', 'ownerId', 'status', 'createdAt', 'updatedAt']) &&
               data.title is string && data.title.size() <= 150 &&
               data.description is string && data.description.size() <= 5000 &&
               data.category is string && data.category.size() <= 50 &&
               data.githubUrl is string && 
               data.demoUrl is string && 
               data.imageUrl is string && 
               data.ownerId is string && data.ownerId == request.auth.uid &&
               data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
               data.createdAt is number && data.updatedAt is number &&
               data.get('upvotesCount', 0) is number;
      }

      allow read: if true; 
      
      allow get: if true; 
      allow list: if (resource.data.status == 'approved') || (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();

      allow create: if isSignedIn() && isValidProject(request.resource.data) && request.resource.data.status == 'pending' && userHasMidenWallet();
      allow update: if isSignedIn() && (
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        (request.auth.uid == resource.data.ownerId && request.resource.data.ownerId == resource.data.ownerId && request.resource.data.status == resource.data.status) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotesCount']) && 
         (request.resource.data.upvotesCount == resource.data.upvotesCount + 1 || request.resource.data.upvotesCount == resource.data.upvotesCount - 1))
      );
      allow delete: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.ownerId);

      match /comments/{commentId} {
        function isValidComment(data) {
          return data.keys().hasAll(['text', 'authorId', 'createdAt']) &&
                 data.text is string && data.text.size() <= 1000 && data.text.size() > 0 &&
                 data.authorId is string && data.authorId == request.auth.uid &&
                 data.createdAt is number;
        }
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(request.resource.data) && userHasMidenWallet();
        allow delete: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.authorId);
      }

      match /upvotes/{upvoteId} {
        function isValidUpvote(data) {
          return data.keys().hasAll(['userId', 'createdAt']) &&
                 data.userId is string && data.userId == request.auth.uid &&
                 data.createdAt is number;
        }
        allow read: if true;
        allow create: if isSignedIn() && isValidUpvote(request.resource.data) && request.auth.uid == upvoteId && userHasMidenWallet();
        allow delete: if isSignedIn() && request.auth.uid == upvoteId;
      }
    }
  }
}
